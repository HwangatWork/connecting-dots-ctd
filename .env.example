# CTD 환경변수 템플릿
# 이 파일을 .env로 복사 후 값을 채우세요
# 실제 값은 절대 이 파일에 기입하지 않습니다 — GitHub Secrets 또는 로컬 .env 사용

# ── 로컬 개발 ──────────────────────────────────────────
# CORS 허용 도메인 (쉼표 구분, *=전체허용)
CORS_ORIGINS=*

# 프론트엔드가 바라볼 API URL
CTD_API_BASE=http://localhost:8000/api/v1

# ── GitHub Secrets (CI/CD 전용) ────────────────────────
# Render 자동 배포: Render 대시보드 → Account Settings → API Keys
# RENDER_API_KEY=rnd_...

# Netlify 자동 배포: Netlify → User Settings → Personal access tokens
# NETLIFY_AUTH_TOKEN=...

# Netlify 사이트 ID: netlify.toml 또는 .netlify/state.json 참조
# NETLIFY_SITE_ID=0f762967-47e8-4fab-9528-0a4fa0fbeb98
